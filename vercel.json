{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/admin/(.*)", "destination": "/admin/$1" }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30
    },
    "api/admin/**/*.js": {
      "maxDuration": 30
    },
    "admin/**/*.js": {
      "maxDuration": 30
    }
  },
  "env": {
    "NODE_ENV": "production"
  }
}
